---
import { cn } from "../lib/utils";

interface Props {
  pct: number;
  latestDate: string;
  hasData?: boolean;
}

const { pct, latestDate, hasData = true } = Astro.props;

function statusMessage(pct: number): string {
  if (pct >= 100) return "YES";
  if (pct >= 90) return "ALMOST";
  if (pct >= 75) return "GETTING THERE";
  if (pct >= 50) return "NOT YET";
  return "NO";
}

const message = hasData ? statusMessage(pct) : "—";
const isYes = message === "YES";
---
<header class="text-left flex flex-col gap-6">
  <h1 class="text-3xl font-semibold tracking-tight">
    Are We ESM Yet?
  </h1>
  <p class={cn("m-0 text-9xl font-bold tracking-tighter", isYes && "text-accent")}>{message}</p>
  <div class="flex flex-col max-w-[280px]">
    <span class="text-3xl font-semibold">{hasData ? `${pct}%` : "—"}</span>
    <span class="text-muted-foreground text-sm">of packages are ESM-ready though</span>
  </div>
  <div class="flex flex-col gap-1">
    <p class="m-0 text-muted-foreground text-xs">
      Last updated: <span id="date-updated" data-date={hasData ? latestDate : undefined}>{latestDate}</span>
    </p>
    <p class="m-0 text-muted-foreground text-xs">
      Next refresh: <span id="next-refresh">Mondays at 06:00 UTC</span>
    </p>
  </div>
</header>
<script>
  (function () {
    const dateEl = document.getElementById("date-updated");
    const rawDate = dateEl?.getAttribute("data-date");
    if (dateEl && rawDate) {
      const d = new Date(rawDate + "T00:00:00");
      if (!isNaN(d.getTime())) {
        dateEl.textContent = d.toLocaleDateString(undefined, {
          year: "numeric",
          month: "short",
          day: "numeric",
        });
      }
    }

    const rtf = new Intl.RelativeTimeFormat(undefined, { numeric: "auto", style: "short" });
    const now = new Date();
    const day = now.getUTCDay();
    const pastSix = now.getUTCHours() >= 6;
    let daysUntilMonday = day === 1 && !pastSix ? 0 : day === 0 ? 1 : day === 1 ? 7 : 8 - day;
    const next = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() + daysUntilMonday, 6, 0, 0));
    const ms = next.getTime() - now.getTime();
    const hours = Math.round(ms / (1000 * 60 * 60));
    const minutes = Math.round(ms / (1000 * 60));
    const el = document.getElementById("next-refresh");
    if (el) el.textContent = hours >= 24 ? rtf.format(Math.floor(hours / 24), "day") : (minutes < 60 ? rtf.format(minutes, "minute") : rtf.format(hours, "hour"));
  })();
</script>
