---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ESM adoption dashboard for the JavaScript/TypeScript ecosystem" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      const s=document.documentElement;const t=localStorage.getItem("theme");const d=window.matchMedia("(prefers-color-scheme: dark)").matches;s.classList.toggle("dark",(t??(d?"dark":"light"))==="dark");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#main" class="sr-only">
      Skip to content
    </a>
    <button
      type="button"
      id="theme-toggle"
      class="fixed top-4 right-4 p-3 min-w-[44px] min-h-[44px] rounded-md text-[var(--muted)] hover:text-[var(--foreground)] hover:bg-[var(--surface)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)] transition-colors"
      aria-label="Toggle theme"
    >
      <svg data-sun class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg data-moon class="dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
    <slot />
    <script>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    </script>
  </body>
</html>
